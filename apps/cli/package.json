  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@devassemble/core": "workspace:*",
    "@devassemble/providers": "workspace:*",
    "@devassemble/types": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "ink": "^5.2.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "ora": "^9.3.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0"
  }
}
