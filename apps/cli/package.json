{
  "name": "@devassemble/cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "devassemble": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
